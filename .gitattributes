# Normalize line endings across platforms
* text=auto

# Force Unix line endings for CI-critical files
*.yml text eol=lf
*.yaml text eol=lf
*.sh text eol=lf
Makefile text eol=lf

# Flutter/Dart
*.dart text eol=lf
*.json text eol=lf

# Binaries — no line ending conversion
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
