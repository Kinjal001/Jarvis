# Jarvis — Environment Variables Template
# Copy this file to .env.dev, .env.staging, or .env.prod and fill in real values.
# NEVER commit the actual .env files — they are gitignored.

# Supabase
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# Sentry
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# App
APP_ENV=dev
APP_VERSION=0.0.1
